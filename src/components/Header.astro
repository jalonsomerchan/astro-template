---
import Container from './Container.astro';
import { siteConfig } from '../config/site';

const homeUrl = import.meta.env.BASE_URL ?? siteConfig.base;
---

<header class="border-b border-[var(--color-border)] bg-white/80 backdrop-blur">
  <Container class="flex items-center justify-between py-4">
    <a class="font-bold tracking-tight" href={homeUrl}>{siteConfig.name}</a>
    <nav aria-label="Navegación principal" class="flex items-center gap-4 text-sm text-[var(--color-muted)]">
      <a class="hover:text-[var(--color-text)]" href={homeUrl}>Inicio</a>
    </nav>
  </Container>
</header>
