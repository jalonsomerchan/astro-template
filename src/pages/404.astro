---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Container from '../components/Container.astro';
import { siteConfig } from '../config/site';

const homeUrl = import.meta.env.BASE_URL ?? siteConfig.base;
---

<BaseLayout title="Página no encontrada" description="La página que buscas no existe.">
  <Container class="py-20 text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-primary)]">Error 404</p>
    <h1 class="mt-3 text-4xl font-black tracking-tight">Página no encontrada</h1>
    <p class="mx-auto mt-4 max-w-xl text-[var(--color-muted)]">
      La página que buscas no existe, se ha movido o todavía no ha sido creada.
    </p>
    <div class="mt-8">
      <Button href={homeUrl}>Volver al inicio</Button>
    </div>
  </Container>
</BaseLayout>
